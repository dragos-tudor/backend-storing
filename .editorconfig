[*.Tests.cs]
dotnet_diagnostic.CA1707.severity = none # Naming: Identifiers should not contain underscores
dotnet_diagnostic.IDE1006.severity = none # Style: Naming rule violation

[*.cs]
dotnet_diagnostic.CA1062.severity = none # Design: Validate arguments of public methods [non-nullable reference types => clear intention => no rule]
# dotnet_diagnostic.CA1303.severity = none # Globalization: Do not pass literals as localized parameters
dotnet_diagnostic.CA1515.severity = none # Maintainability: Consider making public types internal
dotnet_diagnostic.CA2007.severity = none # Reliability: Do not directly await a Task
# dotnet_diagnostic.CS1591.severity = none # Compiler Warning:message severity for generated code files

dotnet_diagnostic.IDE0160.severity = none # Style: Convert to block scoped namespace
dotnet_diagnostic.IDE0040.severity = none # Style: Add accessibility modifiers
dotnet_diagnostic.IDE0022.severity = none # Style: Use block body for method
dotnet_diagnostic.IDE0011.severity = none # Style: Add braces
dotnet_diagnostic.IDE0008.severity = none # Style: Use explicit type
dotnet_diagnostic.IDE0058.severity = none # Style: Expression value is never used
dotnet_diagnostic.IDE0039.severity = none # Style: Use local function
dotnet_diagnostic.IDE0130.severity = none # Style: Namespace does not match folder structure
dotnet_diagnostic.IDE0021.severity = none # Style: Use block body for constructor

[*.cs]
dotnet_diagnostic.RS0016.severity = warning # PublicApiAnalyzers
dotnet_diagnostic.RS0017.severity = warning # PublicApiAnalyzers
dotnet_diagnostic.RS0022.severity = warning # PublicApiAnalyzers
dotnet_diagnostic.RS0024.severity = warning # PublicApiAnalyzers
dotnet_diagnostic.RS0025.severity = warning # PublicApiAnalyzers
dotnet_diagnostic.RS0026.severity = none # PublicApiAnalyzers
dotnet_diagnostic.RS0027.severity = warning # PublicApiAnalyzers
dotnet_diagnostic.RS0036.severity = warning # PublicApiAnalyzers
dotnet_diagnostic.RS0037.severity = warning # PublicApiAnalyzers
dotnet_diagnostic.RS0041.severity = warning # PublicApiAnalyzers