{
	"dockerFile": "Dockerfile",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-dotnettools.csharp",
        "mongodb.mongodb-vscode"
			]
		}
	},
	"mounts": [
		{ "source": "nuget", "target": "/root/.nuget", "type": "volume" },
    { "source": "/media/dragos/storage/devcontainers", "target": "/var/lib/containers", "type": "bind" }
	],
	"containerEnv": {
		"DATA_PROTECTION_KEY": "HFm8fYbLyEarjjlGBj5r9Q==",
    "MSSQL_SA_PASSWORD": "p@ssw0rd!",
    "MONGO_INITDB_ROOT_USERNAME": "sa",
    "MONGO_INITDB_ROOT_PASSWORD": "p@ssw0rd!",
    "SHELL": "/bin/bash"
	},
	"runArgs": [
		"--name=backend-storing",
    "--hostname=storing",
    "--network=storing-network",
		"--privileged"
	],
  "postCreateCommand": "chmod u+x .devcontainer/*.sh; sh .devcontainer/post-create-command.sh",
  "postStartCommand": "sh .devcontainer/post-start-command.sh"
}
