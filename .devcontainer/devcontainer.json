{
	"dockerFile": "Dockerfile",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-dotnettools.csharp",
        "mongodb.mongodb-vscode"
			]
		}
	},
	"mounts": [
		{ "source": "nuget", "target": "/root/.nuget", "type": "volume" }
	],
	"containerEnv": {
    "MSSQL_SA_PASSWORD": "p@ssw0rd!",
    "MONGO_INITDB_ROOT_USERNAME": "sa",
    "MONGO_INITDB_ROOT_PASSWORD": "p@ssw0rd!",
    "CONTAINERS_REGISTRIES_CONF": "/workspaces/backend-storing/.podman/registries.conf",
    "CONTAINERS_STORAGE_CONF": "/workspaces/backend-storing/.podman/storage.conf"
	},
	"runArgs": [
		"--name=backend-storing",
    "--add-host=host.containers.internal:host-gateway",
    "--network=storing-network",
		"--privileged"
	],
	"initialCommand": "chmod +x .podman/*.sh; .podman/initializing.sh",
  "postCreateCommand": ".podman/creating.sh",
  "postStartCommand": ".podman/starting.sh"
}
